# LetsChat production env (Caddy reverse-proxy track)
# Copy to .env in repo root before starting production services.
#
# ─────────────────────────────────────────────────────────────────────────────
# Two kinds of settings live in this file:
#
#   • REQUIRED (env-only) — secrets, infrastructure pointers, deploy-time
#     identity. Read once at startup. Changes here require a restart.
#
#   • FIRST-RUN DEFAULTS — operational policy (registration mode, rate
#     limits, SMTP). On a fresh deployment these seed a row in the runtime
#     SystemConfig table. AFTER that, the live values come from the admin
#     panel at /admin/config and these env vars are IGNORED. Edit them via
#     the panel; the env file becomes documentation, not configuration.
# ─────────────────────────────────────────────────────────────────────────────


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                       REQUIRED — env only                                 ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Auth backend (core-api / ASP.NET Core Identity + PostgreSQL) ─────────────
AUTH_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# Optional. Required only by /admin/accounts/rebind (legacy escape hatch).
AUTH_ADMIN_API_KEY=

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Username and database name have defaults (letschat / auth); only the password
# is mandatory.
POSTGRES_USER=letschat
POSTGRES_DB=auth
POSTGRES_PASSWORD=change-me-generate-with-openssl-rand-hex-32

# ── Bootstrap admin (first run only) ─────────────────────────────────────────
# Seeds the initial admin account. After your first sign-in, change the
# password in the admin panel and unset these for subsequent deploys.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-strong-password
ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Must match `keys:` in livekit/config.prod.yaml.
LIVEKIT_API_KEY=letschat-prod
LIVEKIT_API_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
MINIO_PUBLIC_ENDPOINT=https://files.example.com
# Browser CORS for presigned downloads. "*" works; pin to the web origin to
# lock it down (must match APP_DOMAIN with scheme, e.g. https://app.example.com).
MINIO_CORS_ALLOW_ORIGIN=https://app.example.com

# ── Discovery endpoint used by app startup (Setup → Server URL) ──────────────
# Served by core-api at:
#   https://auth.example.com/.well-known/letschat.json
# There is no separate `connect` subdomain — auth.<domain> is the same upstream
# (core-api:8787) and doubles as the discovery entrypoint users paste in Setup.
DISCOVERY_SPACETIMEDB_URI=wss://chat.example.com
DISCOVERY_AUTH_URL=https://auth.example.com
DISCOVERY_LIVEKIT_URL=wss://lk.example.com
DISCOVERY_DATABASE=letschat

# ── Caddy hostnames ───────────────────────────────────────────────────────────
# These names must point (DNS-only) to your server public IP.
AUTH_DOMAIN=auth.example.com
CHAT_DOMAIN=chat.example.com
FILES_DOMAIN=files.example.com
LIVEKIT_DOMAIN=lk.example.com
APP_DOMAIN=app.example.com

# ── Hosted web client ─────────────────────────────────────────────────────────
# Baked into the browser bundle at build time so app.<domain> auto-connects to
# this instance (skips the desktop setup screen). Point at the auth subdomain —
# it serves the discovery document.
VITE_WEB_CONNECT_URL=https://auth.example.com
# WebSocket compression for the DB stream in browsers: "gzip" (default, bandwidth
# win) or "none". The client also auto-downgrades to none if a gzip socket fails.
VITE_WEB_WS_COMPRESSION=gzip

# ── Email transport selector ─────────────────────────────────────────────────
# `smtp` for real delivery, `log` to write outgoing mail to the container log
# (dev / smoke tests only). The connection details below are first-run
# defaults; the transport selector itself stays env-only.
EMAIL_SENDER=smtp

# ── Client version compatibility (optional overrides) ────────────────────────
# Both default to the running core-api version. Set to pin a specific desktop
# app version for /downloads/{os} and future client-update gating.
RECOMMENDED_CLIENT_VERSION=
MIN_CLIENT_VERSION=

# ── SpacetimeDB service identity (plan 1.5) ──────────────────────────────────
# core-api uses these to push instance-admin changes (currently: space-create
# policy) into the SpacetimeDB chat-domain module.
#
# Bootstrap once after `spacetime publish`:
#   1. Generate a token:   spacetime token gen
#   2. Note its identity:  spacetime identity new --no-save (or read from the
#                          generated token's payload)
#   3. As the publisher, promote it:
#        spacetime call letschat set_user_admin <identity> true
#   4. Set SPACETIMEDB_SERVICE_TOKEN below and restart core-api.
#
# When unset, the /admin/config "Spaces" card renders read-only with a hint.
SPACETIMEDB_HTTP_URL=http://spacetimedb:3000
SPACETIMEDB_MODULE_NAME=letschat
SPACETIMEDB_SERVICE_TOKEN=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║   FIRST-RUN DEFAULTS — ignored once /admin/config has the row             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Registration policy ──────────────────────────────────────────────────────
# Seed values for the runtime SystemConfig row. After first start, change
# these in /admin/config — edits here have no effect on a running deployment.
REQUIRE_EMAIL_CONFIRMATION=true
REQUIRE_ADMIN_APPROVAL=false

# ── Email (SMTP) connection details ──────────────────────────────────────────
# Required at first start when EMAIL_SENDER=smtp. After first start, manage
# these via /admin/config → Email / SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=true
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=LetsChat

# ── Rate limiting (per IP, per window, on auth endpoints) ────────────────────
# Seed values. Tune in /admin/config → Rate limiting.
RATE_LIMIT_PERMIT=10
RATE_LIMIT_WINDOW_SECONDS=300
