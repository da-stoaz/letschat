# LetsChat production env (Caddy reverse-proxy track)
# Copy to .env in repo root before starting production services.

# ── Auth service ──────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Must match `keys:` in livekit/config.prod.yaml.
LIVEKIT_API_KEY=letschat-prod
LIVEKIT_API_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
MINIO_PUBLIC_ENDPOINT=https://files.example.com

# ── Discovery endpoint used by app startup (Setup → Server URL) ──────────────
# Caddy will expose this at:
#   https://connect.example.com/.well-known/letschat.json
DISCOVERY_SPACETIMEDB_URI=wss://chat.example.com
DISCOVERY_AUTH_URL=https://auth.example.com
DISCOVERY_LIVEKIT_URL=wss://lk.example.com
DISCOVERY_DATABASE=letschat

# ── Caddy hostnames ───────────────────────────────────────────────────────────
# These names must point (DNS-only) to your server public IP.
AUTH_DOMAIN=auth.example.com
CHAT_DOMAIN=chat.example.com
FILES_DOMAIN=files.example.com
LIVEKIT_DOMAIN=lk.example.com
CONNECT_DOMAIN=connect.example.com
