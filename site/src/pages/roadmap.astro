---
import Layout from "@/layouts/Layout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { GITHUB_DISCUSSIONS, GITHUB_ISSUE_NEW } from "@/lib/site";

const updatedAt = "June 16, 2026";

// Delivered and merged to main.
const shipped = [
  {
    id: "Plan 1",
    focus: "Admin Control Panel & Identity",
    blurb: "An authoritative .NET auth backend and a browser-based admin panel.",
    items: [
      "core-api rebuilt on .NET 10 / ASP.NET Core Identity backed by PostgreSQL.",
      "Email verification, per-IP rate limiting, and an admin approval workflow.",
      "Razor admin panel — users, pending queue, system config, audit log — on a non-public listener.",
      "Password reset end-to-end and production deployment cutover.",
    ],
  },
  {
    id: "Plan 1.5",
    focus: "Space Permissions & Discovery",
    blurb: "Control over who can create spaces, and a public surface to find and join them.",
    items: [
      "Configurable space-creation policy, propagated into the chat-domain admin gate.",
      "Opt-in discoverability with descriptions and topic tags; a Discover panel with search and tag filters.",
      "Request-to-join flow for invite-only spaces — approve, decline, and re-request.",
      "Per-owner anti-spam quota and instance-admin moderation (un-list any space).",
    ],
  },
  {
    id: "Plan 1.6",
    focus: "Hosted Web Client & SpacetimeDB 2.5",
    blurb: "LetsChat in the browser, plus the realtime engine moved onto the current release line.",
    items: [
      "Hosted browser client at app.<domain> — single-tenant, auto-discovers its instance, no install.",
      "Reliability-first WebSocket compression with automatic downgrade so a browser can never get stranded.",
      "SpacetimeDB bumped 2.2 → 2.5 in lockstep (CLI, npm SDK, Rust crate, server image).",
      "MinIO browser CORS, web join links, and a dismissable \"also on desktop\" prompt.",
    ],
  },
];

// Sequenced ahead — roughly in priority order. Direction: Spaces with
// Discord-like behaviour (community servers, not team workspaces).
const upcoming = [
  {
    id: "Windows Code Signing",
    focus: "Signed Windows installers",
    priority: "P0",
    status: "Now",
    effort: "~days",
    goals: [
      "Sign the Windows build so SmartScreen/AV stop flagging LetsChat as malware.",
      "Wire signing into the release CI; verify macOS notarization parity.",
      "Highest-leverage adoption fix — done before storage tiering starts.",
    ],
  },
  {
    id: "Plan 2",
    focus: "Storage Tiering & Data Safety",
    priority: "P0",
    status: "Next",
    effort: "~5 weeks",
    goals: [
      "Keep only a bounded hot working set in SpacetimeDB to cap server RAM.",
      "Mirror everything to a PostgreSQL cold archive via a .NET replication worker; serve old history from it.",
      "Turn destructive schema migrations into safe wipe-and-rebuild, and add scheduled backups of all data.",
    ],
  },
  {
    id: "OTA Updates",
    focus: "Client & server auto-update",
    priority: "P1",
    status: "Planned",
    effort: "~1–2 weeks",
    goals: [
      "Tauri auto-updater for the desktop client over a signed update feed (builds on Windows code signing).",
      "Automate the self-hosted server upgrade — today it's 100% manual (docker compose pull + spacetime publish); make it a one-command, safe update.",
      "Staged rollout with version gating (already exposed in /.well-known); scheduled right after Plan 2.",
    ],
  },
  {
    id: "Plan 3",
    focus: "Voice & Media Quality",
    priority: "P1",
    status: "Planned",
    effort: "~2 weeks",
    goals: [
      "Adaptive/simulcast video resolution that auto-downscales for weak connections.",
      "Per-user and master audio volume controls.",
      "Extend noise suppression to the web client (Krisp already ships on desktop).",
    ],
  },
  {
    id: "Plan 4",
    focus: "Space Operations & Limits",
    priority: "P1",
    status: "Planned",
    effort: "Multi-week",
    goals: [
      "Chunked/multipart MinIO uploads so large files aren't capped by the proxy body limit.",
      "Per-space role & access management (Discord-style roles) plus per-space/instance storage quotas.",
      "Drop the core-api↔SpacetimeDB admin-identity coupling; add operator-facing server logging.",
    ],
  },
  {
    id: "Plan 5",
    focus: "Search & Group DMs",
    priority: "P2",
    status: "Planned",
    effort: "~3 weeks",
    goals: [
      "Full-text search across spaces and DMs — wiring up the currently-stubbed search UI.",
      "Group direct messages.",
    ],
  },
  {
    id: "Plan 6",
    focus: "Full UI Redesign",
    priority: "P2",
    status: "Planned",
    effort: "Multi-week",
    goals: [
      "Deliberate ground-up visual redesign rather than incremental patches.",
      "Profile popup cards, right-click context menus, and a custom window header rail.",
      "UI and notification sounds.",
    ],
  },
  {
    id: "Plan 7",
    focus: "End-to-End Encryption",
    priority: "P2",
    status: "Planned",
    effort: "Multi-week",
    goals: [
      "Encrypt DMs first, then attachments and calls (LiveKit insertable streams), then spaces.",
      "Per-conversation keys wrapped per device; all decryption happens on-device.",
      "Key epochs rotate on membership change for re-readable, multi-device history.",
    ],
  },
  {
    id: "Later / Ideas",
    focus: "Scheduled later or idea-stage",
    priority: "Idea",
    status: "Deferred",
    effort: "Unscheduled",
    goals: [
      "Localisation (i18n) — agreed, scheduled for a later milestone.",
      "Native mobile app, public integration API, and MCP integration.",
      "Multi-instance client and an on-device offline cache.",
    ],
  },
];
---

<Layout title="LetsChat Roadmap | Plans and Delivery" description="LetsChat roadmap: shipped milestones and the sequenced plans ahead — Windows code signing, storage tiering, OTA updates, voice quality, a full UI redesign, and end-to-end encryption.">
  <SiteHeader active="roadmap" />

  <main class="max-w-7xl mx-auto px-5 sm:px-6 py-14 space-y-10">
    <section class="roadmap-hero">
      <div>
        <p class="inline-flex text-xs text-muted-foreground border border-border rounded-full px-3 py-1">Updated: {updatedAt}</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight mt-4 mb-3">Roadmap: shipped milestones and the plans ahead</h1>
        <p class="text-muted-foreground max-w-3xl leading-relaxed">
          LetsChat is built plan by plan. This roadmap tracks what has shipped and the sequenced
          work ahead — each plan builds on the one before it. There are no fixed calendar dates;
          plans land in order as they're completed.
        </p>
      </div>

      <div class="roadmap-kpis">
        <article>
          <p class="kpi-value">3</p>
          <p class="kpi-label">Plans shipped</p>
        </article>
        <article>
          <p class="kpi-value">1</p>
          <p class="kpi-label">Next up</p>
        </article>
        <article>
          <p class="kpi-value">8</p>
          <p class="kpi-label">Planned &amp; later</p>
        </article>
      </div>
    </section>

    <section class="priority-box">
      <h2 class="text-xl font-semibold mb-3">How to read this</h2>
      <div class="grid md:grid-cols-3 gap-3 text-sm">
        <article>
          <p class="font-semibold">Shipped</p>
          <p class="text-muted-foreground">Delivered and merged into <code>main</code>.</p>
        </article>
        <article>
          <p class="font-semibold">Next / Planned</p>
          <p class="text-muted-foreground">Sequenced and scoped; later plans depend on earlier ones.</p>
        </article>
        <article>
          <p class="font-semibold">Optional / Deferred</p>
          <p class="text-muted-foreground">Nice-to-have or idea-stage; may be skipped or scheduled later.</p>
        </article>
      </div>
    </section>

    <section>
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-5">Shipped</h2>
      <div class="shipped-grid">
        {shipped.map((milestone) => (
          <article class="shipped-card">
            <div class="timeline-head">
              <div>
                <p class="timeline-window">{milestone.id}</p>
                <h3>{milestone.focus}</h3>
              </div>
              <span class="status-chip status-shipped">Shipped</span>
            </div>
            <p class="shipped-blurb">{milestone.blurb}</p>
            <ul class="timeline-goals">
              {milestone.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-5">Plans ahead</h2>
      <div class="timeline-list">
        {upcoming.map((milestone) => (
          <article class="timeline-card">
            <div class="timeline-head">
              <div>
                <p class="timeline-window">{milestone.id}</p>
                <h3>{milestone.focus}</h3>
              </div>
              <div class="timeline-meta">
                <span class={`priority-chip priority-${milestone.priority.toLowerCase()}`}>{milestone.priority}</span>
                <span class={`status-chip status-${milestone.status.toLowerCase()}`}>{milestone.status}</span>
                <span class="effort-chip">{milestone.effort}</span>
              </div>
            </div>

            <ul class="timeline-goals">
              {milestone.goals.map((goal) => <li>{goal}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="feedback-strip">
      <div>
        <h2 class="text-xl font-semibold mb-1">Roadmap input channels</h2>
        <p class="text-sm text-muted-foreground">Use GitHub discussions for feature direction and issue forms for execution blockers.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href={GITHUB_DISCUSSIONS} target="_blank" rel="noopener" class="feedback-primary">Request a feature</a>
        <a href={GITHUB_ISSUE_NEW} target="_blank" rel="noopener" class="feedback-secondary">Report Blocking Bug</a>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  .roadmap-hero {
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 1.2rem;
    padding: 1.25rem;
    background:
      linear-gradient(170deg, oklch(0.21 0.02 240 / 0.96), oklch(0.16 0.01 245 / 0.93)),
      radial-gradient(900px 320px at 90% 0%, oklch(0.72 0.1 220 / 0.2), transparent 66%);
    display: grid;
    gap: 1.1rem;
    align-items: end;
  }

  .roadmap-kpis {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .roadmap-kpis article {
    border-radius: 0.9rem;
    border: 1px solid oklch(1 0 0 / 0.13);
    background: oklch(0.17 0.01 245 / 0.9);
    padding: 0.8rem;
  }

  .kpi-value {
    font-size: 1.3rem;
    font-weight: 650;
    margin: 0 0 0.2rem;
  }

  .kpi-label {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-muted-foreground);
  }

  .priority-box {
    border: 1px solid oklch(1 0 0 / 0.11);
    border-radius: 1rem;
    padding: 1rem;
    background: oklch(0.19 0.01 245 / 0.9);
  }

  .priority-box code {
    font-size: 0.85em;
    padding: 0.05rem 0.3rem;
    border-radius: 0.3rem;
    background: oklch(1 0 0 / 0.08);
  }

  .shipped-grid {
    display: grid;
    gap: 0.9rem;
  }

  .shipped-card {
    border: 1px solid oklch(0.6 0.13 150 / 0.32);
    border-left: 3px solid oklch(0.62 0.14 150 / 0.8);
    border-radius: 1rem;
    padding: 1rem;
    background: linear-gradient(175deg, oklch(0.21 0.02 175 / 0.5), oklch(0.18 0.01 245 / 0.92));
  }

  .shipped-blurb {
    margin: 0 0 0.6rem;
    font-size: 0.9rem;
    color: var(--color-foreground);
  }

  .timeline-list {
    position: relative;
    display: grid;
    gap: 0.9rem;
  }

  .timeline-list::before {
    content: "";
    position: absolute;
    left: 0.55rem;
    top: 0.65rem;
    bottom: 0.65rem;
    width: 2px;
    background: linear-gradient(180deg, oklch(0.75 0.1 220 / 0.7), oklch(0.65 0.1 240 / 0.22));
    border-radius: 999px;
  }

  .timeline-card {
    position: relative;
    margin-left: 1.45rem;
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 1rem;
    padding: 1rem;
    background: linear-gradient(175deg, oklch(0.21 0.01 245 / 0.95), oklch(0.18 0.01 245 / 0.92));
  }

  .timeline-card::before {
    content: "";
    position: absolute;
    left: -1.03rem;
    top: 1.22rem;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    background: oklch(0.76 0.1 220);
    box-shadow: 0 0 0 5px oklch(0.76 0.1 220 / 0.19);
  }

  .timeline-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.7rem;
  }

  .timeline-window {
    margin: 0 0 0.2rem;
    font-size: 0.73rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted-foreground);
  }

  .timeline-head h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  .timeline-meta {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .priority-chip,
  .status-chip,
  .effort-chip {
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 1px solid oklch(1 0 0 / 0.15);
    white-space: nowrap;
  }

  .priority-p0 {
    background: oklch(0.66 0.2 25 / 0.16);
    color: oklch(0.88 0.08 30);
  }

  .priority-p1 {
    background: oklch(0.76 0.12 85 / 0.2);
    color: oklch(0.9 0.07 100);
  }

  .priority-p2 {
    background: oklch(0.62 0.1 235 / 0.16);
    color: oklch(0.84 0.06 230);
  }

  .priority-idea {
    background: oklch(0.5 0.02 245 / 0.25);
    color: var(--color-muted-foreground);
  }

  .effort-chip {
    color: var(--color-muted-foreground);
    background: oklch(0.17 0.01 245 / 0.85);
    text-transform: none;
    letter-spacing: 0;
  }

  .status-chip {
    color: var(--color-muted-foreground);
    background: oklch(0.17 0.01 245 / 0.85);
  }

  .status-shipped {
    background: oklch(0.6 0.13 150 / 0.18);
    color: oklch(0.86 0.12 155);
    border-color: oklch(0.6 0.13 150 / 0.4);
  }

  .status-next {
    background: oklch(0.62 0.1 235 / 0.2);
    color: oklch(0.87 0.07 230);
    border-color: oklch(0.62 0.1 235 / 0.42);
  }

  .timeline-goals {
    margin: 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.35rem;
    color: var(--color-muted-foreground);
    font-size: 0.85rem;
  }

  .feedback-strip {
    border: 1px solid oklch(1 0 0 / 0.13);
    border-radius: 1rem;
    padding: 1rem;
    background: linear-gradient(165deg, oklch(0.22 0.02 240 / 0.94), oklch(0.17 0.01 245 / 0.92));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .feedback-primary,
  .feedback-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    padding: 0.62rem 0.9rem;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .feedback-primary {
    background: var(--color-accent-blue);
    color: white;
  }

  .feedback-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-muted-foreground);
  }

  .feedback-secondary:hover {
    border-color: var(--color-border-hover);
    color: var(--color-foreground);
  }

  @media (min-width: 900px) {
    .shipped-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .roadmap-hero {
      grid-template-columns: 1.4fr 0.6fr;
    }
  }

  @media (max-width: 720px) {
    .roadmap-kpis {
      grid-template-columns: 1fr;
    }

    .timeline-head {
      flex-direction: column;
    }
  }
</style>
