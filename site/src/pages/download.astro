---
import Layout from "@/layouts/Layout.astro";

const GITHUB_REPO = "da-stoaz/letschat";
---

<Layout
  title="Download LetsChat"
  description="Download LetsChat for macOS, Windows, or Linux. Free, open source, self-hosted."
>

  <!-- Nav -->
  <header class="border-b border-border sticky top-0 z-50 backdrop-blur-sm bg-background-translucent">
    <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-semibold text-foreground tracking-tight hover:opacity-80 transition-opacity">LetsChat</a>
      <a href={`https://github.com/${GITHUB_REPO}`} target="_blank" rel="noopener"
         class="text-sm text-muted-foreground hover:text-foreground transition-colors">
        GitHub
      </a>
    </nav>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-20">

    <div class="text-center mb-12">
      <h1 class="text-4xl font-semibold tracking-tight mb-3">Download LetsChat</h1>
      <p id="version-badge" class="text-sm text-muted-foreground">Loading latest version…</p>
    </div>

    <!-- Platform cards -->
    <div class="flex flex-col gap-3" id="download-cards">

      <!-- macOS -->
      <div id="card-mac" data-platform="mac"
           class="platform-card rounded-xl border border-border bg-card p-5 flex items-center justify-between gap-4 transition-colors">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-muted flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 814 1000" fill="currentColor">
              <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-42.3-150.3-110.7C113.2 686.9 75 530.4 75 381.4c0-210.6 137.2-322 272.1-322 67.9 0 123.9 44.6 166.3 44.6 40.6 0 103.7-47.6 179.3-47.6 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium">macOS</p>
            <p class="text-xs text-muted-foreground">Universal — Apple Silicon &amp; Intel</p>
          </div>
        </div>
        <a href="#" data-asset="mac"
           class="download-link shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-md bg-muted text-sm font-medium hover:bg-muted-hover transition-colors opacity-50 pointer-events-none">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span>.dmg</span>
        </a>
      </div>

      <!-- Windows x64 -->
      <div id="card-win-x64" data-platform="windows"
           class="platform-card rounded-xl border border-border bg-card p-5 flex items-center justify-between gap-4 transition-colors">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-muted flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 88 88" fill="currentColor">
              <path d="M0 12.402l35.687-4.86.016 34.423-35.67.20zm35.67 33.529l.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium">Windows</p>
            <p class="text-xs text-muted-foreground">x64 — Intel &amp; AMD</p>
          </div>
        </div>
        <div class="flex gap-2 shrink-0">
          <a href="#" data-asset="windows-x64-msi"
             class="download-link inline-flex items-center gap-2 px-4 py-2 rounded-md bg-muted text-sm font-medium hover:bg-muted-hover transition-colors opacity-50 pointer-events-none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span>.msi</span>
          </a>
          <a href="#" data-asset="windows-x64-exe"
             class="download-link inline-flex items-center gap-2 px-4 py-2 rounded-md bg-muted text-sm font-medium hover:bg-muted-hover transition-colors opacity-50 pointer-events-none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span>.exe</span>
          </a>
        </div>
      </div>

      <!-- Windows ARM -->
      <div id="card-win-arm" data-platform="windows-arm"
           class="platform-card rounded-xl border border-border bg-card p-5 flex items-center justify-between gap-4 transition-colors">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-muted flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 88 88" fill="currentColor">
              <path d="M0 12.402l35.687-4.86.016 34.423-35.67.20zm35.67 33.529l.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium">Windows</p>
            <p class="text-xs text-muted-foreground">ARM64 — Snapdragon &amp; Surface</p>
          </div>
        </div>
        <a href="#" data-asset="windows-arm-msi"
           class="download-link shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-md bg-muted text-sm font-medium hover:bg-muted-hover transition-colors opacity-50 pointer-events-none">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span>.msi</span>
        </a>
      </div>

      <!-- Linux -->
      <div id="card-linux" data-platform="linux"
           class="platform-card rounded-xl border border-border bg-card p-5 flex items-center justify-between gap-4 transition-colors">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-muted flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M9 9h.01M15 9h.01"/><path d="M9 14s1 2 3 2 3-2 3-2"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium">Linux</p>
            <p class="text-xs text-muted-foreground">x64 — Ubuntu, Debian, &amp; AppImage</p>
          </div>
        </div>
        <div class="flex gap-2 shrink-0">
          <a href="#" data-asset="linux-deb"
             class="download-link inline-flex items-center gap-2 px-4 py-2 rounded-md bg-muted text-sm font-medium hover:bg-muted-hover transition-colors opacity-50 pointer-events-none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span>.deb</span>
          </a>
          <a href="#" data-asset="linux-appimage"
             class="download-link inline-flex items-center gap-2 px-4 py-2 rounded-md bg-muted text-sm font-medium hover:bg-muted-hover transition-colors opacity-50 pointer-events-none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span>.AppImage</span>
          </a>
        </div>
      </div>

    </div>

    <!-- Error state -->
    <p id="release-error" class="hidden text-center text-sm text-muted-foreground mt-8">
      Could not load release data.
      <a href={`https://github.com/${GITHUB_REPO}/releases`} target="_blank" rel="noopener"
         class="underline underline-offset-2 hover:text-foreground">Browse releases on GitHub.</a>
    </p>

    <p class="text-center text-xs text-muted-foreground mt-8">
      All releases are signed and notarized. View all versions on
      <a href={`https://github.com/${GITHUB_REPO}/releases`} target="_blank" rel="noopener"
         class="underline underline-offset-2 hover:text-foreground">GitHub Releases</a>.
    </p>

  </main>

  <!-- Footer -->
  <footer class="border-t border-border">
    <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted-foreground">
      <span>© {new Date().getFullYear()} Felix Steinberger</span>
      <div class="flex items-center gap-4">
        <a href="/" class="hover:text-foreground transition-colors">Home</a>
        <a href={`https://github.com/${GITHUB_REPO}`} target="_blank" rel="noopener" class="hover:text-foreground transition-colors">GitHub</a>
      </div>
    </div>
  </footer>

</Layout>

<script>
  const REPO = "da-stoaz/letschat";

  const MATCHERS: Record<string, RegExp> = {
    "mac":              /\.dmg$/i,
    "windows-x64-msi": /[_-]x64[_-].*\.msi$|(?<!aarch64)(?<!arm64)\.msi$/i,
    "windows-x64-exe": /[_-]x64[_-].*\.exe$|(?<!aarch64)(?<!arm64)(?<!setup)\.exe$|NSIS.*\.exe$/i,
    "windows-arm-msi": /aarch64.*\.msi$|arm64.*\.msi$/i,
    "linux-deb":        /\.deb$/i,
    "linux-appimage":   /\.AppImage$/i,
  };

  async function loadRelease() {
    try {
      const res = await fetch(`https://api.github.com/repos/${REPO}/releases/latest`, {
        headers: { Accept: "application/vnd.github.v3+json" },
      });
      if (!res.ok) throw new Error("no release");
      const release = await res.json();

      const badge = document.getElementById("version-badge");
      if (badge) badge.textContent = `Latest: ${release.tag_name}`;

      const assets: { name: string; browser_download_url: string }[] = release.assets;

      for (const [key, pattern] of Object.entries(MATCHERS)) {
        const asset = assets.find((a) => pattern.test(a.name));
        const link = document.querySelector<HTMLAnchorElement>(`[data-asset="${key}"]`);
        if (link && asset) {
          link.href = asset.browser_download_url;
          link.classList.remove("opacity-50", "pointer-events-none");
        }
      }

      const ua = navigator.userAgent;
      let platformId: string | null = null;
      if (/Mac/i.test(ua))        platformId = "card-mac";
      else if (/Win/i.test(ua))   platformId = "card-win-x64";
      else if (/Linux/i.test(ua)) platformId = "card-linux";

      if (platformId) {
        const card = document.getElementById(platformId);
        if (card) card.style.borderColor = "var(--accent-blue)";
      }

    } catch {
      const badge = document.getElementById("version-badge");
      if (badge) badge.textContent = "";
      document.getElementById("release-error")?.classList.remove("hidden");
    }
  }

  loadRelease();
</script>
