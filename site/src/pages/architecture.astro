---
import Layout from "@/layouts/Layout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
---

<Layout title="LetsChat Architecture" description="Technical deep dive for LetsChat architecture.">
  <SiteHeader active="architecture" />

  <main class="max-w-4xl mx-auto px-6 py-20">
    <section class="rounded-2xl border border-border bg-card p-8 md:p-10">
      <p class="text-xs text-muted-foreground border border-border rounded-full inline-flex px-3 py-1">Coming soon</p>
      <h1 class="text-4xl font-semibold tracking-tight mt-4 mb-3">Architecture</h1>
      <p class="text-muted-foreground leading-relaxed">
        This page is intentionally kept minimal for now. The system architecture is currently changing, and the deep-dive documentation will be published once the next major structure settles.
      </p>
    </section>
  </main>

  <SiteFooter />
</Layout>
