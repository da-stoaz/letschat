---
/**
 * Copy-to-clipboard code block.
 *
 * Pure Astro + Tailwind + one tiny delegated script (bundled once per page,
 * no framework runtime). Pass the snippet as the `code` prop; an optional
 * `label` renders a header chip (e.g. a filename or shell name).
 *
 *   <CodeBlock label="terminal" code={`docker compose up -d`} />
 */
interface Props {
  code: string;
  /** Small header label — a filename, "terminal", "yaml", etc. */
  label?: string;
}

const { code, label } = Astro.props;
---

<figure class="code-block" data-code-block>
  <div class="code-block-bar">
    <span class="code-block-label">{label ?? "shell"}</span>
    <button type="button" class="copy-btn" data-copy aria-label="Copy code to clipboard">
      <svg class="copy-icon" viewBox="0 0 24 24" aria-hidden="true">
        <rect x="9" y="9" width="11" height="11" rx="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
      <svg class="check-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" />
      </svg>
      <span class="copy-text">Copy</span>
    </button>
  </div>
  <pre><code>{code}</code></pre>
</figure>

<script>
  // One delegated listener for every CodeBlock on the page.
  document.addEventListener("click", async (event) => {
    const btn = (event.target as HTMLElement)?.closest<HTMLButtonElement>("[data-copy]");
    if (!btn) return;

    const block = btn.closest("[data-code-block]");
    const code = block?.querySelector("code")?.textContent ?? "";
    if (!code) return;

    try {
      await navigator.clipboard.writeText(code);
    } catch {
      // Fallback for non-secure contexts / older engines.
      const ta = document.createElement("textarea");
      ta.value = code;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      try {
        document.execCommand("copy");
      } catch {
        /* give up silently */
      }
      ta.remove();
    }

    btn.classList.add("is-copied");
    const text = btn.querySelector(".copy-text");
    if (text) text.textContent = "Copied";
    window.setTimeout(() => {
      btn.classList.remove("is-copied");
      if (text) text.textContent = "Copy";
    }, 1600);
  });
</script>

<style>
  .code-block {
    margin: 0;
    border-radius: 0.8rem;
    border: 1px solid oklch(1 0 0 / 0.12);
    background: oklch(0.115 0.008 250);
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.04) inset,
      0 10px 26px oklch(0 0 0 / 0.28);
    overflow: hidden;
  }

  .code-block-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.55rem 0.4rem 0.85rem;
    background: oklch(0.17 0.008 250 / 0.7);
    border-bottom: 1px solid oklch(1 0 0 / 0.08);
  }

  .code-block-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: oklch(0.66 0.01 250);
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.6rem;
    border-radius: 0.5rem;
    border: 1px solid oklch(1 0 0 / 0.14);
    background: oklch(0.24 0.01 250 / 0.7);
    color: oklch(0.8 0.01 250);
    font-size: 0.74rem;
    font-weight: 500;
    line-height: 1;
    cursor: pointer;
    transition:
      color 140ms ease,
      border-color 140ms ease,
      background-color 140ms ease;
  }

  .copy-btn:hover {
    color: var(--color-foreground);
    border-color: oklch(0.62 0.18 250 / 0.6);
    background: oklch(0.3 0.02 250 / 0.8);
  }

  .copy-btn:focus-visible {
    outline: 2px solid var(--color-accent-blue);
    outline-offset: 2px;
  }

  .copy-icon,
  .check-icon {
    width: 0.92rem;
    height: 0.92rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .check-icon {
    display: none;
    color: oklch(0.8 0.16 155);
  }

  .copy-btn.is-copied {
    color: oklch(0.85 0.16 155);
    border-color: oklch(0.7 0.16 155 / 0.5);
    background: oklch(0.7 0.16 155 / 0.14);
  }

  .copy-btn.is-copied .copy-icon {
    display: none;
  }

  .copy-btn.is-copied .check-icon {
    display: inline;
  }

  pre {
    margin: 0;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.83rem;
    line-height: 1.65;
    color: oklch(0.9 0.012 240);
    tab-size: 2;
  }

  pre code {
    font-family: inherit;
    white-space: pre;
  }

  /* Scrollbar polish for the horizontal overflow on long commands. */
  pre::-webkit-scrollbar {
    height: 0.5rem;
  }

  pre::-webkit-scrollbar-thumb {
    background: oklch(1 0 0 / 0.14);
    border-radius: 9999px;
  }
</style>
