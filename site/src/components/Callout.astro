---
/**
 * Admonition / callout box for the guides. Three intents so important notes
 * stop disappearing into the grey body text:
 *
 *   note     — neutral blue, "good to know"
 *   warning  — amber, "this will bite you if you skip it"
 *   tip      — cyan/green, "shortcut / nice-to-have"
 *
 *   <Callout type="warning" title="The one exception">…</Callout>
 */
interface Props {
  type?: "note" | "warning" | "tip";
  title?: string;
}

const { type = "note", title } = Astro.props;

const icons: Record<string, string> = {
  note: "M12 16v-4M12 8h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
  warning: "M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z",
  tip: "M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1V18h6v-1.2c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2Z",
};
---

<aside class:list={["callout", `callout-${type}`]} role="note">
  <svg class="callout-icon" viewBox="0 0 24 24" aria-hidden="true">
    <path d={icons[type]} />
  </svg>
  <div class="callout-body">
    {title && <p class="callout-title">{title}</p>}
    <div class="callout-content guide-prose"><slot /></div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 0.8rem;
    padding: 0.95rem 1.1rem;
    border-radius: 0.8rem;
    border: 1px solid var(--c-border);
    background:
      linear-gradient(180deg, var(--c-tint), transparent 140%),
      oklch(0.2 0.008 250 / 0.55);
    border-left: 3px solid var(--c-accent);
  }

  .callout-icon {
    flex: none;
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.1rem;
    fill: none;
    stroke: var(--c-accent);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .callout-body {
    min-width: 0;
  }

  .callout-title {
    margin: 0 0 0.2rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .callout-content {
    font-size: 0.94rem;
  }

  .callout-content :global(p) {
    margin: 0;
  }

  .callout-content :global(p + p) {
    margin-top: 0.5rem;
  }

  .callout-note {
    --c-accent: oklch(0.66 0.16 250);
    --c-border: oklch(0.66 0.16 250 / 0.28);
    --c-tint: oklch(0.66 0.16 250 / 0.08);
  }

  .callout-warning {
    --c-accent: oklch(0.78 0.15 75);
    --c-border: oklch(0.78 0.15 75 / 0.3);
    --c-tint: oklch(0.78 0.15 75 / 0.09);
  }

  .callout-tip {
    --c-accent: oklch(0.78 0.14 185);
    --c-border: oklch(0.78 0.14 185 / 0.3);
    --c-tint: oklch(0.78 0.14 185 / 0.08);
  }
</style>
