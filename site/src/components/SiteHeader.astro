---
import { GITHUB_BASE, GITHUB_OWNER, GITHUB_REPO_NAME } from "@/lib/site";

interface Props {
  active?: "home" | "roadmap" | "changes" | "architecture" | "self-hosting" | "download";
}

const { active = "home" } = Astro.props;
---

<header class="site-nav-wrap sticky top-0 z-50" data-site-nav>
  <div class="site-nav-glass border-b border-border">
    <div class="max-w-7xl mx-auto px-5 sm:px-6">
      <nav class="nav-shell py-3" aria-label="Primary">
        <div class="brand">
          <a href="/" class="brand-logo-link" aria-label="LetsChat home">
            <img src="/letschat-logo.png" alt="LetsChat logo" class="brand-logo" />
          </a>

          <div class="brand-copy">
            <div class="brand-title-row">
              <a href="/" class="brand-name-link">LetsChat</a>
              <a
                href={GITHUB_BASE}
                target="_blank"
                rel="noopener"
                class="brand-github"
                data-github-stars
                data-owner={GITHUB_OWNER}
                data-repo={GITHUB_REPO_NAME}
                aria-label="GitHub repository stars"
              >
                <svg class="star-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 3.4l2.6 5.3 5.8.8-4.2 4.1 1 5.8-5.2-2.8-5.2 2.8 1-5.8L3.6 9.5l5.8-.8L12 3.4z" />
                </svg>
                <span data-stars-number>--</span>
              </a>
            </div>
            <span class="brand-sub">Self-hosted team communication</span>
          </div>
        </div>

        <div class="desktop-nav">
          <a href="/#product" class:list={["nav-link", active === "home" ? "nav-link-active" : "nav-link-idle"]}>Product</a>
          <a href="/roadmap" class:list={["nav-link", active === "roadmap" ? "nav-link-active" : "nav-link-idle"]}>Roadmap</a>
          <a href="/self-hosting" class:list={["nav-link", active === "self-hosting" ? "nav-link-active" : "nav-link-idle"]}>Self-Hosting</a>
          <a href="/download" class="action-btn action-btn-primary">Download</a>
        </div>

        <div class="mobile-actions">
          <a href="/download" class="action-btn action-btn-primary">Download</a>
          <button
            type="button"
            class="menu-toggle"
            aria-label="Toggle navigation"
            aria-controls="mobile-nav-panel"
            aria-expanded="false"
            data-nav-toggle
          >
            Menu
          </button>
        </div>
      </nav>

      <div id="mobile-nav-panel" class="mobile-panel" data-nav-panel>
        <div class="mobile-links">
          <a href="/#product" class:list={["mobile-link", active === "home" ? "mobile-link-active" : "mobile-link-idle"]}>Product</a>
          <a href="/roadmap" class:list={["mobile-link", active === "roadmap" ? "mobile-link-active" : "mobile-link-idle"]}>Roadmap</a>
          <a href="/self-hosting" class:list={["mobile-link", active === "self-hosting" ? "mobile-link-active" : "mobile-link-idle"]}>Self-Hosting</a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  (() => {
    const root = document.querySelector('[data-site-nav]');
    if (!root) return;

    const toggle = root.querySelector('[data-nav-toggle]');
    const panel = root.querySelector('[data-nav-panel]');
    if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

    const close = () => {
      root.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
    };

    toggle.addEventListener('click', () => {
      const open = root.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', close);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) close();
    });

    const formatStars = (value: number): string => {
      if (!Number.isFinite(value)) return '--';
      if (value >= 1000000) return `${(value / 1000000).toFixed(1)}M`;
      if (value >= 1000) return `${(value / 1000).toFixed(1)}k`;
      return String(value);
    };

    const starTargets = root.querySelectorAll('[data-github-stars]');
    if (starTargets.length === 0) return;

    const first = starTargets[0];
    const owner = first.getAttribute('data-owner');
    const repo = first.getAttribute('data-repo');
    if (!owner || !repo) return;

    fetch(`https://api.github.com/repos/${owner}/${repo}`, {
      headers: { Accept: 'application/vnd.github+json' },
    })
      .then((res) => (res.ok ? res.json() : null))
      .then((data) => {
        if (!data || typeof data.stargazers_count !== 'number') return;
        const label = formatStars(data.stargazers_count);
        starTargets.forEach((target) => {
          const node = target.querySelector('[data-stars-number]');
          if (node) node.textContent = label;
        });
      })
      .catch(() => {
        // Keep fallback label.
      });
  })();
</script>

<style>
  .site-nav-wrap {
    backdrop-filter: blur(8px);
  }

  .site-nav-glass {
    background:
      linear-gradient(180deg, oklch(0.15 0.01 245 / 0.88), oklch(0.13 0.01 245 / 0.82)),
      radial-gradient(900px 260px at 5% -120%, oklch(0.72 0.11 215 / 0.12), transparent 60%);
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.62rem;
    min-width: 0;
  }

  .brand-logo-link {
    display: inline-flex;
    flex-shrink: 0;
  }

  .brand-logo {
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 0.75rem;
    background: linear-gradient(145deg, oklch(0.24 0.03 240), oklch(0.16 0.01 250));
    border: 1px solid oklch(1 0 0 / 0.14);
    box-shadow: 0 10px 24px oklch(0 0 0 / 0.25);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .brand-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .brand-name-link {
    font-size: 0.98rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--color-foreground);
    white-space: nowrap;
  }

  .brand-github {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2rem 0.5rem;
    font-size: 0.72rem;
    line-height: 1;
    color: var(--color-muted-foreground);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .brand-github:hover {
    color: var(--color-foreground);
    border-color: var(--color-border-hover);
  }

  .star-icon {
    width: 0.95rem;
    height: 0.95rem;
    fill: currentColor;
  }

  .brand-sub {
    font-size: 0.67rem;
    color: var(--color-muted-foreground);
    line-height: 1.2;
    white-space: nowrap;
  }

  .desktop-nav {
    display: none;
  }

  .mobile-actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-shrink: 0;
  }

  .action-btn,
  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border-radius: 0.65rem;
    padding: 0.55rem 0.72rem;
    border: 1px solid var(--color-border);
    font-size: 0.76rem;
    line-height: 1;
    transition: color 160ms ease, border-color 160ms ease, opacity 160ms ease;
  }

  .menu-toggle {
    background: transparent;
    color: var(--color-muted-foreground);
    cursor: pointer;
  }

  .menu-toggle:hover {
    color: var(--color-foreground);
    border-color: var(--color-border-hover);
  }

  .action-btn-primary {
    background: var(--color-accent-blue);
    border-color: color-mix(in oklab, var(--color-accent-blue) 70%, transparent);
    color: white;
    font-weight: 600;
  }

  .mobile-panel {
    display: none;
    padding-bottom: 0.85rem;
    border-top: 1px solid oklch(1 0 0 / 0.12);
    margin-top: 0.15rem;
  }

  .site-nav-wrap.is-open .mobile-panel {
    display: grid;
    gap: 0.72rem;
    padding-top: 0.72rem;
  }

  .mobile-links {
    display: grid;
    gap: 0.4rem;
  }

  .mobile-link {
    border-radius: 0.68rem;
    border: 1px solid transparent;
    padding: 0.6rem 0.75rem;
    font-size: 0.9rem;
  }

  .mobile-link-active {
    color: var(--color-foreground);
    border-color: var(--color-border);
    background: var(--color-card);
  }

  .mobile-link-idle {
    color: var(--color-muted-foreground);
  }

  .mobile-link-idle:hover {
    color: var(--color-foreground);
    background: color-mix(in oklab, var(--color-card) 78%, transparent);
  }

  .nav-link {
    border-radius: 0.62rem;
    border: 1px solid transparent;
    padding: 0.48rem 0.68rem;
    font-size: 0.85rem;
    white-space: nowrap;
    transition: color 160ms ease, border-color 160ms ease, background-color 160ms ease;
  }

  .nav-link-active {
    color: var(--color-foreground);
    border-color: var(--color-border);
    background: var(--color-card);
  }

  .nav-link-idle {
    color: var(--color-muted-foreground);
  }

  .nav-link-idle:hover {
    color: var(--color-foreground);
    background: color-mix(in oklab, var(--color-card) 78%, transparent);
  }

  @media (min-width: 640px) {
    .action-btn,
    .menu-toggle {
      font-size: 0.82rem;
    }
  }

  @media (min-width: 1024px) {
    .mobile-actions,
    .mobile-panel {
      display: none !important;
    }

    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 0.46rem;
      margin-left: auto;
      min-width: 0;
    }

    .action-btn {
      font-size: 0.8rem;
      padding: 0.52rem 0.75rem;
    }

    .brand-logo {
      width: 2.45rem;
      height: 2.45rem;
    }

    .brand-name-link {
      font-size: 1.02rem;
    }

    .brand-github {
      font-size: 0.74rem;
      padding: 0.22rem 0.55rem;
    }

    .star-icon {
      width: 1rem;
      height: 1rem;
    }
  }
</style>
