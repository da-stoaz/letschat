# Vite production build — loaded automatically by `vite build` / `tauri build`.
# Fill in your actual domain before building the distributable app.
VITE_AUTH_SERVICE_URL=https://auth.yourdomain.com
VITE_SPACETIMEDB_URI=wss://chat.yourdomain.com
VITE_SPACETIMEDB_DATABASE=letschat
VITE_LIVEKIT_URL=ws://lk.yourdomain.com:44380
VITE_APP_BASE_URL=https://yourdomain.com
