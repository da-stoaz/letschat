# Copy to .env and fill in real values before running docker-compose.prod.yml
# Generate secrets with: openssl rand -hex 32

# ── Auth service ──────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Must also be set in livekit/config.prod.yaml under the "keys:" section.
LIVEKIT_API_KEY=letschat-prod
LIVEKIT_API_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Public endpoint — the URL clients use to PUT (upload) and GET (download) files.
# Route this through a Cloudflare Tunnel subdomain, e.g. files.yourdomain.com
# If using CF Tunnel set this to:  https://files.yourdomain.com
# If exposing the port directly set this to: http://<your-public-ip>:44390
MINIO_PUBLIC_ENDPOINT=https://files.yourdomain.com

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Create a tunnel at dash.cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
