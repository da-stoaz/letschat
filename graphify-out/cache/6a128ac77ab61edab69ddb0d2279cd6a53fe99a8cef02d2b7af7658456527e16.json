ates(SPACETIMEDB_URI)\n    const errors: string[] = []\n\n    for (const [index, candidate] of uriCandidates.entries()) {\n      const isLastCandidate = index === uriCandidates.length - 1\n      try {\n        await connectWithUri(candidate, SPACETIMEDB_DATABASE, isLastCandidate)\n\n        if (candidate !== SPACETIMEDB_URI) {\n          const currentConfig = useServerConfigStore.getState().config\n          if (currentConfig && currentConfig.spacetimedbUri === SPACETIMEDB_URI) {\n            useServerConfigStore.getState().setConfig({\n              ...currentConfig,\n              spacetimedbUri: candidate,\n            })\n          }\n        }\n        return\n      } catch (error) {\n        errors.push(`${candidate} -> ${getConnectionErrorDetails(error)}`)\n      }\n    }\n\n    throw new Error(\n      `SpacetimeDB connection failed at ${SPACETIMEDB_URI}. Tried ${uriCandidates.length} URI(s): ${errors.join('; ')}`,\n    )\n  })", "source_file": "/Users/stoaz/Source/Space/letschat/src/lib/spacetimedb/connection.ts", "source_location": "L235"}, {"caller_nid": "connection_disconnect", "callee": "offlineReducer", "source_file": "/Users/stoaz/Source/Space/letschat/src/lib/spacetimedb/connection.ts", "source_location": "L276"}, {"caller_nid": "connection_disconnect", "callee": "unsubscribe", "source_file": "/Users/stoaz/Source/Space/letschat/src/lib/spacetimedb/connection.ts", "source_location": "L279"}, {"caller_nid": "connection_disconnect", "callee": "setStatus", "source_file": "/Users/stoaz/Source/Space/letschat/src/lib/spacetimedb/connection.ts", "source_location": "L285"}, {"caller_nid": "connection_disconnect", "callee": "getState", "source_file": "/Users/stoaz/Source/Space/letschat/src/lib/spacetimedb/connection.ts", "source_location": "L285"}, {"caller_nid": "connection_disconnect", "callee": "resetClientState", "source_file": "/Users/stoaz/Source/Space/letschat/src/lib/spacetimedb/connection.ts", "source_location": "L286"}, {"caller_nid": "connection_call