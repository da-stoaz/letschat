# LetsChat production reverse-proxy map.
# Domains are provided via docker-compose.prod.caddy.yml environment variables.
#
# core-api binds the public API on container port 8787 and the admin Razor
# pages on 8788. Only 8787 is fronted by Caddy; the admin port stays bound
# to 127.0.0.1 on the host and is reached over SSH port-forward.

{$AUTH_DOMAIN} {
  reverse_proxy core-api:8787
}

{$CHAT_DOMAIN} {
  # Desktop clients talk to SpacetimeDB over the WebSocket /subscribe path only.
  # The raw HTTP /sql endpoint is an unauthenticated read of every `public`
  # table, so block it at the public edge. core-api reaches /sql over the
  # internal Docker network (service name `spacetimedb`), not through Caddy, so
  # this does not affect server-side reads. Defense-in-depth: the sensitive
  # tables are also private at the data layer (see server/src/schema.rs).
  @sql path */sql
  respond @sql 403

  reverse_proxy spacetimedb:3000
}

{$FILES_DOMAIN} {
  reverse_proxy minio:44390
}

{$LIVEKIT_DOMAIN} {
  reverse_proxy livekit:44380
}

# Serves the public landing page, /.well-known/letschat.json discovery, and
# /downloads/{os} installer resolver. Same upstream as auth.<domain>.
{$CONNECT_DOMAIN} {
  reverse_proxy core-api:8787
}
