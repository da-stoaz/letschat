{
  "name": "letschat",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "scripts": {
    "version:bump": "bun scripts/bump-version.ts",
    "dev": "vite",
    "tauri": "tauri",
    "build": "tsc -b && vite build",
    "build:local": "bun run build",
    "tauri:build:local": "tauri build",
    "downloads:sync": "bun scripts/sync-downloads.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "auth:dev": "APP_ENV=dev cargo run --manifest-path auth-service/Cargo.toml",
    "core-api:dev": "ASPNETCORE_ENVIRONMENT=Development dotnet run --project core-api/src/CoreApi/CoreApi.csproj",
    "core-api:dev:lan": "bun run scripts/core-api-lan.ts",
    "core-api:test": "dotnet test core-api/CoreApi.slnx",
    "core-api:migrate": "dotnet run --project core-api/tools/CoreApi.Migrator -- --sqlite auth-service/auth.db",
    "spacetime:generate": "spacetime generate --lang typescript --out-dir src/generated --module-path server --yes",
    "spacetime:publish": "spacetime publish --server http://localhost:4300 letschat --module-path server",
    "spacetime:reset": "spacetime publish --server http://localhost:4300 letschat --module-path server --delete-data --yes",
    "services:up": "docker compose -f docker-compose.dev.yml up -d",
    "services:down": "docker compose -f docker-compose.dev.yml down",
    "services:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "services:reset": "docker compose -f docker-compose.dev.yml down -v",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "livekit-client": "^2.19.0",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "spacetimedb": "^2.2.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12"
  }
}
